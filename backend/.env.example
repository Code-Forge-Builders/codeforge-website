# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=codeforge-website
DB_SSLMODE=disable

# SMTP (email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_TLS=true
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=CodeForge Website

# Server (optional, defaults shown)
PORT=8080
# IP_HASH_SALT=...

# Job workers (optional, defaults shown)
# JOB_WORKER_AMOUNT_FACTOR=1.0
# EMAIL_JOB_WORKERS_MAX_AMOUNT=32
